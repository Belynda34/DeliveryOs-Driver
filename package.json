    "@react-native-firebase/functions": "^25.1.0",
    "@react-native-firebase/messaging": "^25.1.0",
    "@react-navigation/native": "^7.3.13",
    "@react-navigation/native-stack": "^7.18.5",
    "@reduxjs/toolkit": "^2.12.0",
    "@rnmapbox/maps": "^10.3.2",
